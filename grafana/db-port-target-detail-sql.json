    {
      "id": 8,
      "type": "stat",
      "title": "Approx Down Minutes (Events)",
      "datasource": {
        "type": "postgres",
        "uid": "grafana-postgresql-datasource"
      },
      "gridPos": {
        "x": 0,
        "y": 20,
