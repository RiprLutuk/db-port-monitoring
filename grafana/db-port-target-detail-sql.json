          "rawQuery": true,
          "rawSql": "WITH samples AS (\n  SELECT r.checked_at, r.is_up, lag(r.is_up) OVER (ORDER BY r.checked_at) AS previous_is_up\n  FROM monitoring.db_port_blackbox_probe_results r\n  WHERE $__timeFilter(r.checked_at) AND ('$env' = '%' OR r.environment = '$env') AND ('$db_type' = '%' OR r.db_type = '$db_type') AND r.target_name = '$target'\n)\nSELECT count(*) FILTER (WHERE previous_is_up IS NOT NULL AND previous_is_up <> is_up)::bigint AS status_changes\nFROM samples;",
