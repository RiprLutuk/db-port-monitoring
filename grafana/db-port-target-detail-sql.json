            "uid": "grafana-postgresql-datasource"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH bounds AS (\n  SELECT $__timeFrom()::timestamptz AS from_at, $__timeTo()::timestamptz AS to_at\n)\nSELECT coalesce(round(sum(extract(epoch FROM least(coalesce(e.down_end, now()), b.to_at) - greatest(e.down_start, b.from_at)))::numeric / 60.0, 2), 0) AS approx_down_minutes\nFROM monitoring.db_port_blackbox_downtime_events e\nCROSS JOIN bounds b\nWHERE e.down_start < b.to_at AND coalesce(e.down_end, now()) > b.from_at AND ('$env' = '%' OR e.environment = '$env') AND ('$db_type' = '%' OR e.db_type = '$db_type') AND e.target_name = '$target';",
          "refId": "A",
          "sql": {
