          "rawQuery": true,
          "rawSql": "SELECT\n  t.target_name,\n  t.environment,\n  t.db_type,\n  t.instance,\n  t.host,\n  t.port,\n  t.criticality,\n  t.team,\n  CASE WHEN r.is_up = 1 THEN 'UP' ELSE 'DOWN' END AS current_status,\n  r.checked_at AS last_probe_at,\n  round(r.latency_ms::numeric, 2) AS latency_ms\nFROM monitoring.db_port_blackbox_targets t\nLEFT JOIN LATERAL (\n  SELECT checked_at, is_up, latency_ms\n  FROM monitoring.db_port_blackbox_probe_results r\n  WHERE r.target_name = t.target_name\n  ORDER BY checked_at DESC\n  LIMIT 1\n) r ON true\nWHERE ('$env' = '%' OR t.environment = '$env') AND ('$db_type' = '%' OR t.db_type = '$db_type') AND t.target_name = '$target';",
