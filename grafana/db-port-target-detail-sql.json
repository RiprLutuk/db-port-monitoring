          "rawQuery": true,
          "rawSql": "WITH minute_samples AS (\n  SELECT\n    date_trunc('minute', r.checked_at) AS period_minute,\n    min(r.is_up) AS is_up\n  FROM monitoring.db_port_blackbox_probe_results r\n  WHERE $__timeFilter(r.checked_at) AND ('$env' = '%' OR r.environment = '$env') AND ('$db_type' = '%' OR r.db_type = '$db_type') AND r.target_name = '$target'\n  GROUP BY 1\n)\nSELECT coalesce(round(avg(is_up)::numeric * 100, 2), 0) AS availability_pct\nFROM minute_samples;",
