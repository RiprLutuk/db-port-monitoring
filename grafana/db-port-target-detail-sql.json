          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest AS (\n  SELECT\n    r.checked_at,\n    r.target_name,\n    r.environment,\n    r.db_type,\n    r.instance,\n    r.criticality,\n    r.team,\n    r.host,\n    r.port,\n    r.is_up,\n    r.latency_ms\n  FROM monitoring.db_port_blackbox_probe_results r\n  WHERE ('$env' = '%' OR r.environment = '$env') AND ('$db_type' = '%' OR r.db_type = '$db_type') AND r.target_name = '$target'\n  ORDER BY r.checked_at DESC\n  LIMIT 1\n)\nSELECT coalesce(max(is_up), 0)::bigint AS current_status FROM latest;",
